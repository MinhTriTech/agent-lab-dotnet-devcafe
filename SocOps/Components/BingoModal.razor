<div class="fixed inset-0 bg-black\/50 flex items-center justify-center p-4 z-50">
    <div class="bg-burgundy border-4 border-yellow p-6 max-w-xs w-full text-center shadow-bold rounded-lg animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="text-4xl font-bold text-yellow mb-2 text-shadow-lg">BINGO!</h2>
        <p class="text-white mb-6 font-bold text-lg">YOU GOT A LINE!</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-yellow text-burgundy font-bold py-3 px-6 rounded-lg border-3 border-burgundy active:bg-accent transition-colors text-lg">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
