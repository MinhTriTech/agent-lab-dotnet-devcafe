<div class="flex flex-col items-center justify-center min-h-full p-6 bg-gray-100">
    <div class="text-center max-w-sm">
        <h1 class="text-5xl font-bold text-yellow mb-2 text-shadow-lg stroke-bold">SOC OPS</h1>
        <p class="text-2xl text-teal mb-8 font-bold text-shadow-sm">Social Bingo</p>

        <div class="bg-burgundy rounded-lg p-6 shadow-bold border-4 border-yellow mb-8">
            <h2 class="font-bold text-yellow mb-3 text-2xl text-shadow-sm">HOW TO PLAY</h2>
            <ul class="text-left text-white text-sm space-y-2 font-bold text-lg">
                <li>🎯 Find people who match</li>
                <li>👆 Tap a square when found</li>
                <li>⭐ Get 5 in a row to WIN!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-yellow text-burgundy font-bold py-4 px-8 rounded-lg text-2xl border-4 border-burgundy active:bg-teal transition-colors shadow-bold">
            START GAME
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
