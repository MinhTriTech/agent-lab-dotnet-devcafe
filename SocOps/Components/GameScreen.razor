@using SocOps.Models

<div class="flex flex-col min-h-full bg-gray-100">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 bg-burgundy border-b-4 border-yellow">
        <button
            @onclick="OnReset"
            class="text-yellow text-sm px-3 py-1.5 rounded font-bold border-2 border-yellow active:bg-yellow active:text-burgundy">
            ← BACK
        </button>
        <h1 class="font-bold text-3xl text-yellow text-shadow-lg">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-yellow text-sm py-2 px-4 font-bold bg-teal">
        TAP A SQUARE WHEN YOU FIND A MATCH!
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-yellow text-burgundy text-center py-2 font-bold text-lg border-4 border-burgundy text-shadow-sm">
            🎉 BINGO! YOU GOT A LINE!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
